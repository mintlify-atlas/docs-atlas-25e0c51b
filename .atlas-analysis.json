    "DashboardOptionsBuilder.WithBasicAuth / WithApiKey / WithHostAuthentication / WithCustomAuth",
    "TimeTickerEntity / CronTickerEntity",
    "TickerStatus enum",
    "RunCondition enum",
    "TickerResult<TEntity>"
  ]
