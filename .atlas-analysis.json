  "keyFeatures": [
    "Zero-reflection, AOT-ready source-generated job registration",
    "Cron and one-off time-based job scheduling",
    "EF Core persistence (PostgreSQL, SQL Server, SQLite, MySQL)",
    "Redis persistence with multi-node distributed coordination",
    "Built-in real-time SignalR dashboard with no paid add-ons",
    "Configurable retry policies and backoff intervals",
    "Job chaining with conditional run conditions (OnSuccess, OnFailure, etc.)",
    "Typed request payloads with GZip compression support",
    "OpenTelemetry tracing instrumentation",
    "TickerQ Hub for centralized cross-application scheduling"
  ],
  "publicApiSurface": [
    "AddTickerQ(services, options)",
    "UseTickerQ(host, startMode)",
    "[TickerFunction(name, cronExpression, priority, maxConcurrency)]",
    "TickerFunctionContext / TickerFunctionContext<TRequest>",
